{
  "name": "@sap-app-factory/testing-kit",
  "version": "0.0.0",
  "private": true,
  "description": "Shared test fixtures and contract-test harness for every port/adapter pair. See CODING_STANDARDS.md § Testing.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b tsconfig.build.json",
    "typecheck": "tsc -b tsconfig.build.json --noEmit",
    "test": "vitest run --coverage"
  },
  "dependencies": {
    "@sap-app-factory/plugin-sdk": "workspace:*",
    "@sap-app-factory/ports": "workspace:*",
    "vitest": "^4.1.10"
  }
}

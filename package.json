{
  "name": "sap-app-factory",
  "version": "0.0.0",
  "private": true,
  "description": "SAP App Factory monorepo root — see PROJECT_STRUCTURE.md",
  "license": "UNLICENSED",
  "packageManager": "pnpm@10.20.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "lint": "pnpm run lint:eslint && pnpm run lint:deps && pnpm run format:check",
    "lint:eslint": "eslint .",
    "lint:deps": "depcruise --config dependency-cruiser.config.cjs .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "infra:up": "docker compose -f infra/docker-compose/docker-compose.yml up -d",
    "infra:down": "docker compose -f infra/docker-compose/docker-compose.yml down",
    "infra:reset": "docker compose -f infra/docker-compose/docker-compose.yml down -v",
    "infra:logs": "docker compose -f infra/docker-compose/docker-compose.yml logs -f"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.1.10",
    "dependency-cruiser": "^18.1.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "turbo": "^2.10.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  }
}

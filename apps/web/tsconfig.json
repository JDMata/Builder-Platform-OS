{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    // Next.js's own bundler (SWC/webpack/Turbopack), not tsc, resolves
    // imports at build time, and its conventions (extensionless relative
    // imports, "page.tsx"/"layout.tsx" file-based routing) are incompatible
    // with tsconfig.base.json's NodeNext + verbatimModuleSyntax, which
    // require explicit ".js" extensions on relative imports. Every other
    // strict-mode rule (strict, noUncheckedIndexedAccess) is inherited
    // unchanged — only module resolution is overridden, and only here.
    "module": "esnext",
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": false,
    "lib": ["dom", "dom.iterable", "esnext"],
    "jsx": "preserve",
    "allowJs": true,
    "noEmit": true,
    "incremental": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules", "vitest.config.ts"]
}

# Copy to infra/.env to override any of these. All have safe dev-only
# defaults baked into docker-compose.yml — this file exists to document
# them and to make overriding a port collision (see README.md) a one-line
# change instead of an edit to docker-compose.yml itself.

# Postgres
SAF_POSTGRES_USER=saf
SAF_POSTGRES_PASSWORD=saf_dev_password
SAF_POSTGRES_DB=sap_app_factory
SAF_POSTGRES_HOST_PORT=55432

# Keycloak (dev IdP — see packages/auth-core's README, SAF-17)
SAF_KEYCLOAK_ADMIN_USER=admin
SAF_KEYCLOAK_ADMIN_PASSWORD=admin_dev_password
SAF_KEYCLOAK_HOST_PORT=8080

# OpenTelemetry Collector
SAF_OTEL_GRPC_HOST_PORT=4317
SAF_OTEL_HTTP_HOST_PORT=4318
SAF_OTEL_HEALTH_HOST_PORT=13133

# OPA (policy engine — see packages/auth-core's README, SAF-17)
SAF_OPA_HOST_PORT=8181

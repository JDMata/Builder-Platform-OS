{
  "realm": "sap-app-factory",
  "enabled": true,
  "sslRequired": "none",
  "clients": [
    {
      "clientId": "sap-app-factory-api-gateway",
      "enabled": true,
      "publicClient": false,
      "protocol": "openid-connect",
      "clientAuthenticatorType": "client-secret",
      "secret": "dev-only-client-secret",
      "redirectUris": ["http://localhost:3001/*"],
      "webOrigins": ["http://localhost:3001"],
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "attributes": {
        "pkce.code.challenge.method": "S256"
      }
    }
  ],
  "users": [
    {
      "username": "dev-user",
      "enabled": true,
      "emailVerified": true,
      "email": "dev-user@example.test",
      "firstName": "Dev",
      "lastName": "User",
      "requiredActions": [],
      "credentials": [
        {
          "type": "password",
          "value": "dev-user-password",
          "temporary": false
        }
      ]
    }
  ]
}
